# Base URL for the Turkish Official Gazette site.
GAZETTE_BASE_URL="https://www.resmigazete.gov.tr"

# Where downloaded PDFs will be stored.
RAW_PDF_DIR="data/raw_pdfs"

# Persistent download queue state (used for idempotency).
QUEUE_FILE="data/download_queue.json"

# Logging level (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL="INFO"

# Llama Cloud API key used by LlamaParse pipeline.
LLAMA_CLOUD_API_KEY="your_llama_cloud_api_key_here"

# Parser output directories.
PARSED_MARKDOWN_DIR="data/parsed_markdown"
PARSED_JSON_DIR="data/parsed_json"

# Parser tuning.
MAX_PAGES_PER_CHUNK=20
PARSER_LANGUAGE="tr"

# Keywords used to filter gazette article titles.
#
# Format: JSON array string. Example:
# KEYWORDS='["imar","kamulaştırma","ihale"]'
KEYWORDS='["imar","kamulaştırma","ihale","tapu","yapı ruhsatı","kıyı kanunu","mera","orman","gayrimenkul","arazi","expropriation","tender","zoning","real estate","land registry"]'

